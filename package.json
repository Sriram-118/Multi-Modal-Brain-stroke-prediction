  "description": "Modern UI for Multi-Modal Stroke Prediction Django Application",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "dev": "tsc --watch",
    "lint": "eslint StrokeApp/static/js/**/*.js",
    "format": "prettier --write StrokeApp/static/js/**/*.js StrokeApp/static/css/**/*.css"
